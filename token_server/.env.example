HMS_APP_ACCESS_KEY=your_100ms_app_access_key
HMS_APP_SECRET=your_100ms_app_secret
PORT=3000

# Optional: specific 100ms template ID. Omit to use the account default template.
# HMS_TEMPLATE_ID=

# Roles must match what is configured in your 100ms template (default: trainer / member).
HMS_ROLE_TRAINER=trainer
HMS_ROLE_MEMBER=member
